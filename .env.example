# Datadog
DD_API_KEY=your_datadog_api_key_here
DD_SITE=us3.datadoghq.com

# MySQL (local docker-compose uses values below automatically)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=kredit
DB_USER=kredit
DB_PASS=kredit
# Or use a full DSN: MYSQL_DSN=mysql:host=xxx;port=3306;dbname=kredit
# MYSQL_USER=kredit
# MYSQL_PASSWORD=kredit

# ACR (for build-push.sh)
ACR_NAME=kreditplusacr
IMAGE_TAG=1.0.0
