# Copy to .env and fill in values before running docker compose up

# Required
DD_API_KEY=your_datadog_api_key_here

# Datadog site — us3.datadoghq.com for most internal accounts
DD_SITE=us3.datadoghq.com

# ACR name (used by build-push.sh)
ACR_NAME=your_acr_name_here

# Image tag (optional, defaults to latest)
IMAGE_TAG=1.0.0
